CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ElevenLabs TTS for flashcard audio (Mexican Spanish)
# Get a key at https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
# Optional: comma-separated voice IDs to randomize among.
# If empty, randomizes across Mexican/Spanish-labeled voices (or all account voices)
ELEVENLABS_VOICE_ID=
# eleven_multilingual_v2 = best quality | eleven_flash_v2_5 = faster/cheaper
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Supabase shared progress (lessons + flashcards)
# Create a project, run supabase/schema.sql, then paste Project URL + anon key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
